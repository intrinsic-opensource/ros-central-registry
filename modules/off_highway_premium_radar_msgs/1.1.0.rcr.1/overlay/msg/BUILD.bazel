load("@rosidl_default_generators//:defs.bzl", "ros_message")

package(default_visibility = ["//visibility:public"])

exports_files(glob(["*.msg"]))

ros_message(
    name = "EgoVehicleData",
    src = "EgoVehicleData.msg",
    deps = [
        "@geometry_msgs//msg:Accel",
        "@geometry_msgs//msg:TwistWithCovariance",
    ],
)

ros_message(
    name = "EgoVehicleInput",
    src = "EgoVehicleInput.msg",
    deps = [
        ":EgoVehicleData",
        "@std_msgs//msg:Header",
    ],
)

ros_message(
    name = "InterferenceIndicator",
    src = "InterferenceIndicator.msg",
)

ros_message(
    name = "LocationAttributes",
    src = "LocationAttributes.msg",
    deps = [
        ":LocationAttributesHeader",
        ":LocationAttributesPacket",
        ":SensorMounting",
        "@std_msgs//msg:Header",
    ],
)

ros_message(
    name = "LocationAttributesHeader",
    src = "LocationAttributesHeader.msg",
    deps = [
        ":OperationMode",
        ":Time",
    ],
)

ros_message(
    name = "LocationAttributesPacket",
    src = "LocationAttributesPacket.msg",
    deps = [
        ":InterferenceIndicator",
        ":MisalignmentPacket",
        ":SensorCoatingPacket",
        ":SensorFieldOfView",
        ":SensorModulationPerformance",
    ],
)

ros_message(
    name = "LocationDataHeader",
    src = "LocationDataHeader.msg",
    deps = [
        ":OperationMode",
        ":Time",
        "@std_msgs//msg:Header",
    ],
)

ros_message(
    name = "LocationDataPacket",
    src = "LocationDataPacket.msg",
    deps = [
        "@std_msgs//msg:Header",
    ],
)

ros_message(
    name = "MisalignmentPacket",
    src = "MisalignmentPacket.msg",
)

ros_message(
    name = "OperationMode",
    src = "OperationMode.msg",
)

ros_message(
    name = "SensorCoatingPacket",
    src = "SensorCoatingPacket.msg",
)

ros_message(
    name = "SensorFieldOfView",
    src = "SensorFieldOfView.msg",
)

ros_message(
    name = "SensorModulationPerformance",
    src = "SensorModulationPerformance.msg",
)

ros_message(
    name = "SensorMounting",
    src = "SensorMounting.msg",
)

ros_message(
    name = "SensorStateInformation",
    src = "SensorStateInformation.msg",
    deps = [
        "@std_msgs//msg:Header",
    ],
)

ros_message(
    name = "Time",
    src = "Time.msg",
)
