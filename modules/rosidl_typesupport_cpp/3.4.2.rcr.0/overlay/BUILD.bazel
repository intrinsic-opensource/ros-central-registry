load("@rosdistro//ament:defs.bzl", "ament_package")

load("@aspect_rules_py//py:defs.bzl", "py_binary", "py_library")
load("@rosdistro//cc:defs.bzl", "ros_local_defines")
load("@rosdistro//python:defs.bzl", "py_pytest")
load("@rules_cc//cc:defs.bzl", "cc_library", "cc_shared_library")

package(default_visibility = ["//visibility:public"])

exports_files(glob(["*.bzl"]))

filegroup(
    name = "interface_templates",
    srcs = glob(["resource/**/*.em"]),
)

### LIBRARIES

HEADERS = glob([
    "include/**/*.h",
    "include/**/*.hpp",
])

DEPENDENCIES = {
    "@rcpputils//:rcpputils": "@rcpputils//:rcpputils_library",
    "@rosidl_typesupport_c//:rosidl_typesupport_c": "@rosidl_typesupport_c//:rosidl_typesupport_c_library",
}

cc_library(
    name = "rosidl_typesupport_cpp_library",
    srcs = glob([
        "src/**/*.hpp",
        "src/**/*.cpp",
    ]),
    hdrs = HEADERS,
    includes = ["include"],
    local_defines = ros_local_defines(),
    deps = DEPENDENCIES.values() + [
        "@rules_cc//cc/runfiles",
    ],
)

cc_shared_library(
    name = "rosidl_typesupport_cpp",
    dynamic_deps = DEPENDENCIES.keys(),
    exports_filter = [":rosidl_typesupport_cpp_library"],
    deps = [":rosidl_typesupport_cpp_library"],
)

py_library(
    name = "rosidl_typesupport_cpp_py",
    srcs = glob(["rosidl_typesupport_cpp/**/*.py"]),
    deps = [
        "@ament_index_python",
        "@rosidl_cli",
        "@rosidl_generator_cpp",
        "@rosidl_pycommon",
    ],
)

genrule(
    name = "cli_rename",
    srcs = ["bin/rosidl_typesupport_cpp"],
    outs = ["bin/rosidl_typesupport_cpp.py"],
    cmd = "cp $(location :bin/rosidl_typesupport_cpp) $(location :bin/rosidl_typesupport_cpp.py)",
)

py_binary(
    name = "cli",
    srcs = [":bin/rosidl_typesupport_cpp.py"],
    main = ":bin/rosidl_typesupport_cpp.py",
    deps = [":rosidl_typesupport_cpp_py"],
)


### PACKAGING

ament_package(
    name = "ament_package",
    package_xml = "package.xml",
    headers = HEADERS,
    libraries = [":rosidl_typesupport_cpp"],
    deps = [
        "@ament_cmake_core//:ament_package",
        "@ament_cmake_gtest//:ament_package",
        "@ament_cmake_pytest//:ament_package",
        "@ament_cmake_ros_core//:ament_package",
        "@ament_index_python//:ament_package",
        "@ament_lint_auto//:ament_package",
        "@ament_lint_common//:ament_package",
        "@performance_test_fixture//:ament_package",
        "@rcpputils//:ament_package",
        "@rcutils//:ament_package",
        "@rosdistro//:ament_package",
        "@rosidl_cli//:ament_package",
        "@rosidl_generator_cpp//:ament_package",
        "@rosidl_generator_type_description//:ament_package",
        "@rosidl_pycommon//:ament_package",
        "@rosidl_runtime_c//:ament_package",
        "@rosidl_runtime_cpp//:ament_package",
        "@rosidl_typesupport_c//:ament_package",
        "@rosidl_typesupport_interface//:ament_package",
        "@rosidl_typesupport_introspection_cpp//:ament_package",
    ]
)
