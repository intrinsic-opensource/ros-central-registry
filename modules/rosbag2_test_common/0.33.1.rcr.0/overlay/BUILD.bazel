load("@rosdistro//ament:defs.bzl", "ament_package")

load("@rosdistro//cc:defs.bzl", "ros_local_defines")
load("@rules_cc//cc:defs.bzl", "cc_library", "cc_shared_library")

package(default_visibility = ["//visibility:public"])

### LIBRARIES

HEADERS = glob(["include/**/*.hpp"])

DEPENDENCIES = {
    "@rclcpp//:rclcpp": "@rclcpp//:rclcpp_library",
    "@rclcpp_action//:rclcpp_action": "@rclcpp_action//:rclcpp_action_library",
    "@rcutils//:rcutils": "@rcutils//:rcutils_library",
    "@rcpputils//:rcpputils": "@rcpputils//:rcpputils_library",
}

cc_library(
    name = "rosbag2_test_common_library",
    hdrs = HEADERS,
    includes = ["include"],
    local_defines = ros_local_defines(),
    deps = DEPENDENCIES.values() + [
        "@test_msgs//:test_msgs_cc",
    ],
)

cc_shared_library(
    name = "rosbag2_test_common",
    dynamic_deps = DEPENDENCIES.keys(),
    exports_filter = [":rosbag2_test_common_library"],
    deps = [":rosbag2_test_common_library"],
)


### PACKAGING

ament_package(
    name = "ament_package",
    package_xml = "package.xml",
    headers = HEADERS,
    libraries = [":rosbag2_test_common"],
    deps = [
        "@ament_cmake//:ament_package",
        "@ament_cmake_python//:ament_package",
        "@ament_lint_auto//:ament_package",
        "@ament_lint_common//:ament_package",
        "@rclcpp//:ament_package",
        "@rclcpp_action//:ament_package",
        "@rcpputils//:ament_package",
        "@rcutils//:ament_package",
        "@rosdistro//:ament_package",
        "@test_msgs//:ament_package",
    ]
)
