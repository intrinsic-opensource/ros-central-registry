load("@aspect_rules_py//py:defs.bzl", "py_library")
load("@rosdistro//ament:defs.bzl", "ament_index", "ament_package")
load("@rosdistro//python:defs.bzl", "py_pytest")

package(default_visibility = ["//visibility:public"])

### DATA

ament_index(
    name = "ament_index",
    package_xml = "package.xml",
)

### PYTHON MODULE

py_library(
    name = "ros2param",
    srcs = glob(["ros2param/**/*.py"]),
    data = [
        ":ament_index",
    ] + glob(["ros2param/py.typed"]),
    imports = ["."],
    deps = [
        "@ros2cli",
    ],
)

### TESTS

[
    py_pytest(
        name = f.split("/")[-1].removesuffix(".py"),
        srcs = [f],
        args = [
            "-p",
            "launch_testing.pytest.hooks",
        ],
        deps = [
            ":ros2param",
            "@launch",
            "@launch_testing",
            "@launch_testing_ros",
            "@rules_python//python/runfiles",
        ],
    )
    for f in glob(
        ["test/test_*.py"],
        exclude = [
            "**/test_flake8.py",
            "**/test_pep257.py",
            "**/test_copyright.py",
            "**/test_xmllint.py",
            "**/test_cli.py",
        ], allow_empty = True)
]


### PACKAGING

ament_package(
    name = "ament_package",
    package_xml = "package.xml",
    deps = [
        ":ament_index",
        "@ament_copyright//:ament_package",
        "@ament_flake8//:ament_package",
        "@ament_pep257//:ament_package",
        "@ament_xmllint//:ament_package",
        "@launch//:ament_package",
        "@launch_ros//:ament_package",
        "@launch_testing//:ament_package",
        "@launch_testing_ros//:ament_package",
        "@rcl_interfaces//:ament_package",
        "@rclpy//:ament_package",
        "@ros2cli//:ament_package",
        "@ros2node//:ament_package",
        "@ros2service//:ament_package",
        "@rosdistro//:ament_package",
    ]
)
