load("@rosdistro//ament:defs.bzl", "ament_index", "ament_package")
load("@rosdistro//cc:defs.bzl", "collect_transitive_dynamic_deps", "ros_local_defines")
load("@rules_cc//cc:defs.bzl", "cc_binary", "cc_shared_library", "cc_test")

package(default_visibility = ["//visibility:public"])

### AMENT INDEX

ament_index(
    name = "ament_index",
    package_xml = "package.xml",
    deps = [
        "@std_msgs//:ament_package",
        "@test_msgs//:ament_package",
        "@rclcpp//:ament_package",
        "@rcpputils//:ament_package",
        "@rosbag2_cpp//:ament_index",
        "@rosbag2_compression//:ament_index",
        "@rosbag2_compression_zstd//:ament_index",
        "@rosbag2_storage//:ament_index",
        "@rosbag2_storage_default_plugins//:ament_index",
    ]
)

### TESTS

TEST_DEPENDENCIES = {
    "@rclcpp//:rclcpp": "@rclcpp//:rclcpp_library",
    "@rosbag2_cpp//:rosbag2_cpp": "@rosbag2_cpp//:rosbag2_cpp_library",
    "@rosbag2_compression_zstd//:rosbag2_compression_zstd": "@rosbag2_compression_zstd//:rosbag2_compression_zstd_library",
    "@rosbag2_storage//:rosbag2_storage": "@rosbag2_storage//:rosbag2_storage_library",
    "@rosbag2_test_common//:rosbag2_test_common": "@rosbag2_test_common//:rosbag2_test_common_library",
    "@rosbag2_transport//:rosbag2_transport": "@rosbag2_transport//:rosbag2_transport_library",
}

collect_transitive_dynamic_deps(
    name = "transitive_dynamic_deps",
    dynamic_deps = TEST_DEPENDENCIES.keys(),
    visibility = ["//visibility:private"],
)

[
    cc_test(
        name = test,
        srcs = ["test/rosbag2_tests/{0}.cpp".format(test)] + glob(["test/rosbag2_tests/*.hpp"]),
        data = glob(["resources/**"]) + [":ament_index"],
        local_defines = ros_local_defines() + [
            '_TEST_RESOURCES_DIR_PATH=\\"../rosbag2_tests+/test/rosbag2_tests\\"',
            '_SRC_RESOURCES_DIR_PATH=\\"../rosbag2_tests+/test/rosbag2_tests\\"',
        ],
        dynamic_deps = [":transitive_dynamic_deps"],
        deps = TEST_DEPENDENCIES.values() + [
            "@googletest//:gtest_main",
            "@rosbag2_interfaces//:cc",
            "@std_msgs//:cc",
            "@test_msgs//:cc",
        ],
    )
    for test in [
        "test_converter",
        "test_reindexer",
        "test_rosbag2_cpp_api",
        "test_rosbag2_cpp_get_service_info",
        "test_rosbag2_info_end_to_end",
        "test_rosbag2_play_end_to_end",
        "test_rosbag2_record_end_to_end",
        "test_rosbag2_storage_api",
    ]
]


### PACKAGING

ament_package(
    name = "ament_package",
    package_xml = "package.xml",
    deps = [
        ":ament_index",
        "@ament_cmake//:ament_package",
        "@ament_cmake_gmock//:ament_package",
        "@ament_index_cpp//:ament_package",
        "@ament_lint_auto//:ament_package",
        "@ament_lint_common//:ament_package",
        "@rclcpp//:ament_package",
        "@rcpputils//:ament_package",
        "@ros2bag//:ament_package",
        "@rosbag2_compression//:ament_package",
        "@rosbag2_compression_zstd//:ament_package",
        "@rosbag2_cpp//:ament_package",
        "@rosbag2_interfaces//:ament_package",
        "@rosbag2_storage//:ament_package",
        "@rosbag2_storage_default_plugins//:ament_package",
        "@rosbag2_test_common//:ament_package",
        "@rosbag2_transport//:ament_package",
        "@rosdistro//:ament_package",
        "@std_msgs//:ament_package",
        "@test_msgs//:ament_package",
    ]
)
