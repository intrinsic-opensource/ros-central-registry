load("@rosidl_default_generators//:defs.bzl", "ros_message")

package(default_visibility = ["//visibility:public"])

exports_files(glob(["*.msg"]))

ros_message(
    name = "Altimeter",
    src = "Altimeter.msg",
    deps = [
        "@std_msgs//msg:Header",
    ],
)

ros_message(
    name = "Contact",
    src = "Contact.msg",
    deps = [
        ":Entity",
        ":JointWrench",
        "@geometry_msgs//msg:Vector3",
    ],
)

ros_message(
    name = "Contacts",
    src = "Contacts.msg",
    deps = [
        ":Contact",
        "@std_msgs//msg:Header",
    ],
)

ros_message(
    name = "Dataframe",
    src = "Dataframe.msg",
    deps = [
        "@std_msgs//msg:Header",
    ],
)

ros_message(
    name = "Entity",
    src = "Entity.msg",
)

ros_message(
    name = "EntityFactory",
    src = "EntityFactory.msg",
    deps = [
        "@geometry_msgs//msg:Pose",
    ],
)

ros_message(
    name = "EntityWrench",
    src = "EntityWrench.msg",
    deps = [
        ":Entity",
        "@geometry_msgs//msg:Wrench",
        "@std_msgs//msg:Header",
    ],
)

ros_message(
    name = "Float32Array",
    src = "Float32Array.msg",
)

ros_message(
    name = "GuiCamera",
    src = "GuiCamera.msg",
    deps = [
        ":TrackVisual",
        "@geometry_msgs//msg:Pose",
        "@std_msgs//msg:Header",
    ],
)

