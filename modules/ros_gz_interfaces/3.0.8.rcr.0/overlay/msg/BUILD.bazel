    name = "JointWrench",
    src = "JointWrench.msg",
    deps = [
        "@geometry_msgs//msg:Wrench",
        "@std_msgs//msg:Header",
        "@std_msgs//msg:String",
        "@std_msgs//msg:UInt32",
    ],
)

ros_message(
    name = "Light",
    src = "Light.msg",
    deps = [
        "@geometry_msgs//msg:Pose",
        "@geometry_msgs//msg:Vector3",
        "@std_msgs//msg:ColorRGBA",
        "@std_msgs//msg:Header",
    ],
)

ros_message(
    name = "LogicalCameraImage",
    src = "LogicalCameraImage.msg",
    deps = [
        ":LogicalCameraImageModel",
        "@geometry_msgs//msg:Pose",
