load("@rosidl_default_generators//:defs.bzl", "ros_message")

package(default_visibility = ["//visibility:public"])

exports_files(glob(["*.msg"]))

ros_message(
    name = "Builtins",
    src = "Builtins.msg",
    deps = [
        "@builtin_interfaces//msg:Duration",
        "@builtin_interfaces//msg:Time",
    ],
)

ros_message(
    name = "ComplexNestedKey",
    src = "ComplexNestedKey.idl",
    deps = [
        ":NonKeyedWithNestedKey",
    ],
)

ros_message(
    name = "KeyedLong",
    src = "KeyedLong.idl",
)

ros_message(
    name = "KeyedString",
    src = "KeyedString.idl",
)

ros_message(
    name = "NonKeyedWithNestedKey",
    src = "NonKeyedWithNestedKey.idl",
    deps = [
        ":KeyedString",
    ],
)

[
    ros_message(
        name = msg,
        src = "@test_interface_files//msg:{}.msg".format(msg),
    )
    for msg in [
        "BasicTypes",
        "Constants",
        "Defaults",
        "Empty",
        "Strings",
        "WStrings",
    ]
]

[
    ros_message(
        name = msg,
        src = "@test_interface_files//msg:{}.msg".format(msg),
        deps = [
            ":BasicTypes",
            ":Constants",
            ":Defaults",
        ],
    )
    for msg in [
        "Arrays",
        "BoundedPlainSequences",
        "BoundedSequences",
        "UnboundedSequences",
    ]
]

ros_message(
    name = "Nested",
    src = "@test_interface_files//msg:Nested.msg",
    deps = [
        ":BasicTypes",
    ],
)

ros_message(
    name = "MultiNested",
    src = "@test_interface_files//msg:MultiNested.msg",
    deps = [
        ":Arrays",
        ":BoundedSequences",
        ":UnboundedSequences",
    ],
)
