load("@rosdistro//ament:defs.bzl", "ament_package")

load("@aspect_rules_py//py:defs.bzl", "py_library")
load("@rosidl_default_generators//:defs.bzl", "default_generators")
load("@rules_cc//cc:defs.bzl", "cc_library", "cc_test")

package(default_visibility = ["//visibility:public"])

default_generators(
    package_xml = "package.xml",
    deps = [
        "//action:Fibonacci",
        "//action:NestedMessage",
        "//msg:Arrays",
        "//msg:BasicTypes",
        "//msg:BoundedPlainSequences",
        "//msg:BoundedSequences",
        "//msg:Builtins",
        "//msg:ComplexNestedKey",
        "//msg:Constants",
        "//msg:Defaults",
        "//msg:Empty",
        "//msg:KeyedLong",
        "//msg:KeyedString",
        "//msg:MultiNested",
        "//msg:Nested",
        "//msg:NonKeyedWithNestedKey",
        "//msg:Strings",
        "//msg:UnboundedSequences",
        "//msg:WStrings",
        "//srv:Arrays",
        "//srv:BasicTypes",
        "//srv:Empty",
    ],
)

cc_library(
    name = "test_msgs_cc",
    hdrs = glob(["include/**"]),
    includes = ["include"],
    deps = [":cc"],
)

py_library(
    name = "test_msgs_py",
    srcs = glob(["src/test_msgs/**/*.py"]),
    imports = ["src"],
    deps = [":py"],
)

cc_test(
    name = "test_action_typesupport_c_builds",
    srcs = ["test/test_c_type_support.cpp"],
    deps = [
        ":c",
        "@googletest//:gtest",
        "@googletest//:gtest_main",
    ],
)

cc_test(
    name = "test_action_typesupport_cpp_builds",
    srcs = ["test/test_cpp_type_support.cpp"],
    deps = [
        ":cc",
        "@googletest//:gtest",
        "@googletest//:gtest_main",
    ],
)


### PACKAGING

ament_package(
    name = "ament_package",
    package_xml = "package.xml",
    deps = [
        "@ament_cmake//:ament_package",
        "@ament_cmake_gtest//:ament_package",
        "@ament_lint_auto//:ament_package",
        "@ament_lint_common//:ament_package",
        "@builtin_interfaces//:ament_package",
        "@rosdistro//:ament_package",
        "@rosidl_default_generators//:ament_package",
        "@rosidl_default_runtime//:ament_package",
        "@test_interface_files//:ament_package",
    ]
)
