# Imports

load("@rosidl_default_generators//:defs.bzl", "ros_service")

package(default_visibility = ["//visibility:public"])

[
    ros_service(
        name = srv,
        src = "@test_interface_files//srv:{}.srv".format(srv),
    )
    for srv in [
        "BasicTypes",
        "Empty",
    ]
]

ros_service(
    name = "Arrays",
    src = "@test_interface_files//srv:Arrays.srv",
    deps = [
        "//msg:BasicTypes",
        "//msg:Constants",
        "//msg:Defaults",
    ],
)
