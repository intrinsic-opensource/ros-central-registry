load("@rosidl_pycommon//:defs.bzl", "ros_interface")

package(default_visibility = ["//visibility:public"])

exports_files(glob(["*.msg"]))

ros_interface(
    name = "DynamicJointPoint",
    src = "DynamicJointPoint.msg",
    deps = [
        ":DynamicJointsGroup",
    ],
)

ros_interface(
    name = "DynamicJointState",
    src = "DynamicJointState.msg",
)

ros_interface(
    name = "DynamicJointTrajectory",
    src = "DynamicJointTrajectory.msg",
    deps = [
        ":DynamicJointPoint",
    ],
)

ros_interface(
    name = "DynamicJointTrajectoryFeedback",
    src = "DynamicJointTrajectoryFeedback.msg",
    deps = [
        ":DynamicJointState",
    ],
)

ros_interface(
    name = "DynamicJointsGroup",
    src = "DynamicJointsGroup.msg",
)
