load("@rosidl_default_generators//:defs.bzl", "ros_message")

package(default_visibility = ["//visibility:public"])

exports_files(glob(["*.msg"]))

ros_message(
    name = "BEStatus",
    src = "BEStatus.msg",
    deps = [
        "@builtin_interfaces//msg:Time",
    ],
)

ros_message(
    name = "BehaviorLog",
    src = "BehaviorLog.msg",
)

ros_message(
    name = "BehaviorModification",
    src = "BehaviorModification.msg",
)

ros_message(
    name = "BehaviorRequest",
    src = "BehaviorRequest.msg",
    deps = [
        ":Container",
    ],
)

ros_message(
    name = "BehaviorSelection",
    src = "BehaviorSelection.msg",
    deps = [
        ":BehaviorModification",
    ],
)

ros_message(
    name = "BehaviorSync",
    src = "BehaviorSync.msg",
)

ros_message(
    name = "CommandFeedback",
    src = "CommandFeedback.msg",
)

ros_message(
    name = "Container",
    src = "Container.msg",
)

ros_message(
    name = "ContainerStructure",
    src = "ContainerStructure.msg",
    deps = [
        ":Container",
    ],
)

ros_message(
    name = "OutcomeCondition",
    src = "OutcomeCondition.msg",
)

ros_message(
    name = "OutcomeRequest",
    src = "OutcomeRequest.msg",
)

ros_message(
    name = "StateInstantiation",
    src = "StateInstantiation.msg",
