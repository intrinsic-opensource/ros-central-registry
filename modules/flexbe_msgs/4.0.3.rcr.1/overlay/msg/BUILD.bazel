        ":OutcomeCondition",
    ],
)

ros_message(
    name = "StateMapMsg",
    src = "StateMapMsg.msg",
)

ros_message(
    name = "SynthesisErrorCodes",
    src = "SynthesisErrorCodes.msg",
)

ros_message(
    name = "SynthesisRequest",
