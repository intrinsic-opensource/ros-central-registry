load("@rosdistro//ament:defs.bzl", "ament_package")

package(default_visibility = ["//visibility:public"])


### PACKAGING

ament_package(
    name = "ament_package",
    package_xml = "package.xml",
    data = glob(["config/**"]),
    deps = [
        "@ament_cmake//:ament_package",
        "@ament_cmake_gtest//:ament_package",
        "@ament_cmake_target_dependencies//:ament_package",
        "@ament_cpplint//:ament_package",
        "@diagnostic_aggregator//:ament_package",
        "@diagnostic_updater//:ament_package",
        "@geometry_msgs//:ament_package",
        "@lifecycle_msgs//:ament_package",
        "@microstrain_inertial_msgs//:ament_package",
        "@nav_msgs//:ament_package",
        "@nmea_msgs//:ament_package",
        "@rclcpp_lifecycle//:ament_package",
        "@ros_environment//:ament_package",
        "@rosdistro//:ament_package",
        "@rosidl_default_generators//:ament_package",
        "@rosidl_default_runtime//:ament_package",
        "@rtcm_msgs//:ament_package",
        "@sensor_msgs//:ament_package",
        "@std_msgs//:ament_package",
        "@std_srvs//:ament_package",
        "@tf2//:ament_package",
        "@tf2_geometry_msgs//:ament_package",
        "@tf2_ros//:ament_package",
    ]
)
