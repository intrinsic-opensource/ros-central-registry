load("@rosdistro//ament:defs.bzl", "ament_package")

load("@aspect_rules_py//py:defs.bzl", "py_binary", "py_library")
load("@pip_ros//:requirements.bzl", "requirement")
load("@rosdistro//python:defs.bzl", "py_pytest")
load("@rules_python//python/entry_points:py_console_script_binary.bzl", "py_console_script_binary")

package(default_visibility = ["//visibility:public"])

### ENTRYPOINTS

py_binary(
    name = "setup",
    srcs = ["setup.py"],
    visibility = ["//visibility:private"],
    deps = [
        requirement("setuptools"),
    ],
)

genrule(
    name = "entry_points",
    srcs = glob(
        ["**/**"],
        exclude = [
            "*.bazel",
            "*.bzl",
        ],
    ),
    outs = [
        "ament_cppcheck.egg-info/PKG-INFO",
        "ament_cppcheck.egg-info/entry_points.txt",
        "ament_cppcheck.egg-info/top_level.txt",
    ],
    cmd = "$(location :setup) egg_info --egg-base=. && mkdir -p $(@D)/ament_cppcheck.egg-info && cp -r ament_cppcheck.egg-info/* $(@D)/ament_cppcheck.egg-info/",
    tools = [":setup"],
    visibility = ["//visibility:private"],
)

### PYTHON MODULE

py_library(
    name = "ament_cppcheck",
    srcs = glob(["ament_cppcheck/**/*.py"]),
    data = [
        ":entry_points",
        "@cppcheck",
    ],
    imports = ["."],
)

### PYTHON EXECUTABLE

py_console_script_binary(
    name = "cli",
    entry_points_txt = ":entry_points",
    pkg = ":ament_cppcheck",
    script = "ament_cppcheck",
)

### TESTS

[
    py_pytest(
        name = "test_{0}".format(test_name),
        srcs = ["test/test_{0}.py".format(test_name)],
        data = glob(["**/*"]),
        deps = ["@ament_{0}".format(test_name)],
    )
    for test_name in [
        "copyright",
        "flake8",
        "pep257",
        "pycodestyle",
        "xmllint",
    ]
]


### PACKAGING

ament_package(
    name = "ament_package",
    package_xml = "package.xml",
    deps = [
        "@ament_copyright//:ament_package",
        "@ament_flake8//:ament_package",
        "@ament_pep257//:ament_package",
        "@ament_pycodestyle//:ament_package",
        "@ament_xmllint//:ament_package",
        "@rosdistro//:ament_package",
    ]
)
