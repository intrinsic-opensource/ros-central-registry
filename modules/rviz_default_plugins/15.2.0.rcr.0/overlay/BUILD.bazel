cc_test(
    name = "frame_info_test",
    srcs = [
        "rviz_default_plugins/displays/display_test_fixture.cpp",
        "rviz_default_plugins/displays/display_test_fixture.hpp",
        "rviz_default_plugins/displays/tf/frame_info_test.cpp",
