load("@rosdistro//ament:defs.bzl", "ament_index", "ament_package")
load("@rosdistro//cc:defs.bzl", "ros_local_defines")
load("@rules_cc//cc:defs.bzl", "cc_library", "cc_test")

package(default_visibility = ["//visibility:public"])

ament_index(
    name = "ament_index",
)

cc_library(
    name = "rviz_default_plugins",
    srcs = glob(["src/**/*.cpp"]),
    hdrs = glob(
        [
            "include/**/*.hpp",
            "include/**/*.h",
        ],
        allow_empty = True,
    ),
    includes = ["include"],
    local_defines = ros_local_defines() + ["RVIZ_DEFAULT_PLUGINS_BUILDING_LIBRARY"],
    deps = [
        "@geometry_msgs//:cc",
        "@image_transport",
        "@interactive_markers",
        "@laser_geometry",
        "@map_msgs//:cc",
        "@nav_msgs//:cc",
        "@pluginlib//:pluginlib_library",
        "@point_cloud_transport",
        "@rclcpp//:rclcpp_library",
        "@resource_retriever//:cc",
        "@rviz_common",
        "@rviz_rendering",
        "@rviz_resource_interfaces//:cc",
        "@sensor_msgs//:cc",
        "@tf2",
        "@tf2_geometry_msgs",
        "@tf2_ros//:tf2_ros_library",
        "@urdf",
        "@visualization_msgs//:cc",
    ],
)

### TESTS

cc_library(
    name = "ogre_testing_environment",
    srcs = ["rviz_default_plugins/ogre_testing_environment.cpp"],
    hdrs = ["rviz_default_plugins/ogre_testing_environment.hpp"],
    deps = [
        "//shortcuts/rviz_default_plugins",
        "@rviz_rendering",
