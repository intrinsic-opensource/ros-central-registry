load("@aspect_rules_py//py:defs.bzl", "py_library")
load("@pip_ros//:requirements.bzl", "requirement")
load("@rosdistro//ament:defs.bzl", "ament_index", "ament_package")
load("@rosdistro//python:defs.bzl", "py_pytest")

package(default_visibility = ["//visibility:public"])

### DATA

ament_index(
    name = "ament_index",
    lib_data = glob(["example_processes/**"]),
    package_xml = "package.xml",
)

### PYTHON MODULE

py_library(
    name = "launch_testing",
    srcs = glob(["launch_testing/**"]),
    data = [":ament_index"],
    imports = ["."],
    deps = [
        "@ament_index_python",
        "@launch",
        "@osrf_pycommon",
        requirement("pytest"),
    ],
)

### TEST

[
    py_pytest(
        name = f.split("/")[-1].removesuffix(".py"),
        srcs = [f],
        data = glob([
            "test/launch_testing/**",
            "example_processes/**",
        ]) + ["test/conftest.py"],
        deps = [
            ":launch_testing",
            "@rules_python//python/runfiles",
        ],
    )
    for f in glob(
        ["test/launch_testing/**/test_*.py"],
        exclude = [
            "**/test_flake8.py",
            "**/test_pep257.py",
            "**/test_copyright.py",
            "**/test_print_arguments.py",
            "**/test_xml_output.py",
        ], allow_empty = True)
]

[
    py_pytest(
        name = "test_{0}".format(linter),
        srcs = ["test/launch_testing/test_{0}.py".format(linter)],
        data = glob(["**/*"], exclude=["pytest.ini"]),
        deps = [
            ":launch_testing",
            "@ament_{0}".format(linter),
        ],
    )
    for linter in [
        "copyright",
        "flake8",
        "pep257",
    ]
]

[
    py_pytest(
        name = "test_{0}".format(linter),
        srcs = ["test/test_{0}.py".format(linter)],
        data = glob(["**/*"], exclude=["pytest.ini"]),
        deps = [
            ":launch_testing",
            "@ament_{0}".format(linter),
        ],
    )
    for linter in [
        "xmllint",
    ]
]


### PACKAGING

ament_package(
    name = "ament_package",
    package_xml = "package.xml",
    deps = [
        ":ament_index",
        "@ament_copyright//:ament_package",
        "@ament_flake8//:ament_package",
        "@ament_index_python//:ament_package",
        "@ament_pep257//:ament_package",
        "@ament_xmllint//:ament_package",
        "@launch//:ament_package",
        "@launch_xml//:ament_package",
        "@launch_yaml//:ament_package",
        "@rosdistro//:ament_package",
        "@osrf_pycommon//:ament_package",
    ]
)
