load("@rosidl_default_generators//:defs.bzl", "ros_message")

package(default_visibility = ["//visibility:public"])

exports_files(glob(["*.msg"]))

ros_message(
    name = "Accelerometer",
    src = "Accelerometer.msg",
)

ros_message(
    name = "AgentState",
    src = "AgentState.msg",
)

ros_message(
    name = "Ball",
    src = "Ball.msg",
    deps = [
        ":Spherical",
    ],
)

ros_message(
    name = "Beam",
    src = "Beam.msg",
)

ros_message(
    name = "Effector",
    src = "Effector.msg",
    deps = [
        ":Beam",
        ":HingeJointVel",
        ":Say",
        ":UniversalJointVel",
    ],
)

ros_message(
    name = "FieldLine",
    src = "FieldLine.msg",
    deps = [
        ":Spherical",
    ],
)

ros_message(
    name = "Flag",
    src = "Flag.msg",
    deps = [
        ":Spherical",
    ],
)

ros_message(
    name = "ForceResistance",
    src = "ForceResistance.msg",
)

ros_message(
    name = "GameState",
    src = "GameState.msg",
)

ros_message(
    name = "Goalpost",
    src = "Goalpost.msg",
    deps = [
        ":Spherical",
    ],
)

ros_message(
    name = "GyroRate",
    src = "GyroRate.msg",
)

ros_message(
    name = "Hear",
    src = "Hear.msg",
)

ros_message(
    name = "HingeJointPos",
    src = "HingeJointPos.msg",
)

ros_message(
    name = "HingeJointVel",
    src = "HingeJointVel.msg",
)

ros_message(
    name = "Percept",
    src = "Percept.msg",
    deps = [
        ":Accelerometer",
        ":AgentState",
        ":ForceResistance",
        ":GameState",
        ":GyroRate",
        ":Hear",
        ":HingeJointPos",
        ":UniversalJointPos",
        ":Vision",
    ],
)

ros_message(
    name = "Player",
    src = "Player.msg",
    deps = [
        ":Spherical",
    ],
)

ros_message(
    name = "Say",
    src = "Say.msg",
)

ros_message(
    name = "Spherical",
    src = "Spherical.msg",
)

ros_message(
    name = "Synchronize",
    src = "Synchronize.msg",
)

ros_message(
    name = "UniversalJointPos",
    src = "UniversalJointPos.msg",
)

ros_message(
    name = "UniversalJointVel",
    src = "UniversalJointVel.msg",
)

ros_message(
    name = "Vision",
    src = "Vision.msg",
    deps = [
        ":Ball",
        ":FieldLine",
        ":Flag",
        ":Goalpost",
        ":Player",
    ],
)
