load("@rosidl_default_generators//:defs.bzl", "ros_message")

package(default_visibility = ["//visibility:public"])

exports_files(glob(["*.msg"]))

ros_message(
    name = "Bbox2D",
    src = "Bbox2D.msg",
)

ros_message(
    name = "Detections2D",
    src = "Detections2D.msg",
    deps = [
        ":Bbox2D",
        "@sensor_msgs//msg:CompressedImage",
        "@sensor_msgs//msg:Image",
        "@std_msgs//msg:Header",
    ],
)

ros_message(
    name = "Detections2DMultiSource",
    src = "Detections2DMultiSource.msg",
    deps = [
        ":Detections2D",
        "@std_msgs//msg:Header",
    ],
)

ros_message(
    name = "Point2D",
    src = "Point2D.msg",
)

ros_message(
    name = "PointsOfInterest",
    src = "PointsOfInterest.msg",
    deps = [
        ":Point2D",
        "@sensor_msgs//msg:CompressedImage",
        "@sensor_msgs//msg:Image",
        "@std_msgs//msg:Header",
    ],
)

ros_message(
    name = "StreamingString",
    src = "StreamingString.msg",
    deps = [
        "@std_msgs//msg:Header",
    ],
)

ros_message(
    name = "Trackings",
    src = "Trackings.msg",
    deps = [
        ":Bbox2D",
        ":Point2D",
        "@sensor_msgs//msg:CompressedImage",
        "@sensor_msgs//msg:Image",
        "@std_msgs//msg:Header",
    ],
)

ros_message(
    name = "TrackingsMultiSource",
    src = "TrackingsMultiSource.msg",
    deps = [
        ":Trackings",
        "@std_msgs//msg:Header",
    ],
)

ros_message(
    name = "Video",
    src = "Video.msg",
    deps = [
        "@sensor_msgs//msg:CompressedImage",
        "@sensor_msgs//msg:Image",
        "@std_msgs//msg:Header",
    ],
)
