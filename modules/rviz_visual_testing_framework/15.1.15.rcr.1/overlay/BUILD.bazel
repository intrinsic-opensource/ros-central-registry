load("@rosdistro//ament:defs.bzl", "ament_package")

load("@rosdistro//cc:defs.bzl", "ros_local_defines")
load("@rules_cc//cc:defs.bzl", "cc_library")

package(default_visibility = ["//visibility:public"])

cc_library(
    name = "rviz_visual_testing_framework",
    srcs = [
        "src/internal/display_handler.cpp",
        "src/internal/executor.cpp",
        "src/internal/image_tester.cpp",
        "src/internal/rviz_scene_test.cpp",
        "src/internal/transform_message_creator.cpp",
        "src/internal/visual_test.cpp",
        "src/page_objects/base_page_object.cpp",
        "src/page_objects/page_object_with_window.cpp",
        "src/test_helpers.cpp",
        "src/visual_test_fixture.cpp",
    ],
    hdrs = glob(
        [
            "include/**/*.hpp",
            "include/**/*.h",
        ],
        allow_empty = True,
    ),
    includes = ["include"],
    local_defines = ros_local_defines() + [
        "_BUILD_DIR_PATH=\".\"",
        "_SRC_DIR_PATH=\".\"",
    ],
    deps = [
        "@geometry_msgs//:cc",
        "@googletest//:gtest_main",
        "@rclcpp//:rclcpp_library",
        "@rcutils//:rcutils_library",
        "@rules_qt//:qt_widgets",
        "@rviz_common",
        "@rviz_rendering",
        "@std_msgs//:cc",
        "@tf2",
        "@tf2_ros//:tf2_ros_library",
    ],
)


### PACKAGING

ament_package(
    name = "ament_package",
    package_xml = "package.xml",
    data = glob(["config/**"]),
    deps = [
        "@ament_cmake//:ament_package",
        "@ament_cmake_gmock//:ament_package",
        "@ament_cmake_gtest//:ament_package",
        "@ament_lint_auto//:ament_package",
        "@ament_lint_common//:ament_package",
        "@geometry_msgs//:ament_package",
        "@rclcpp//:ament_package",
        "@rcutils//:ament_package",
        "@rosdistro//:ament_package",
        "@rviz_common//:ament_package",
        "@rviz_rendering//:ament_package",
        "@std_msgs//:ament_package",
        "@tf2//:ament_package",
        "@tf2_ros//:ament_package",
    ]
)
