load("@rosdistro//ament:defs.bzl", "ament_package")

package(default_visibility = ["//visibility:public"])

# This is just a trick to automatically pull in the required dependencies
# for actions and services.
[
    alias(
        name = name,
        actual = actual,
    )
    for name, actual in {
        "msg_GoalInfo": "@action_msgs//msg:GoalInfo",
        "msg_GoalStatus": "@action_msgs//msg:GoalStatus",
        "msg_GoalStatusArray": "@action_msgs//msg:GoalStatusArray",
        "srv_CancelGoal": "@action_msgs//srv:CancelGoal",
        "msg_ServiceEventInfo": "@service_msgs//msg:ServiceEventInfo",
    }.items()
]


### PACKAGING

ament_package(
    name = "ament_package",
    package_xml = "package.xml",
    deps = [
        "@action_msgs//:ament_package",
        "@ament_cmake//:ament_package",
        "@ament_cmake_core//:ament_package",
        "@ament_lint_auto//:ament_package",
        "@ament_lint_common//:ament_package",
        "@rosdistro//:ament_package",
        "@rosidl_core_generators//:ament_package",
        "@service_msgs//:ament_package",
    ]
)
