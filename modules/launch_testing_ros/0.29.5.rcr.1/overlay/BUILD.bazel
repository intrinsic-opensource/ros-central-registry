load("@aspect_rules_py//py:defs.bzl", "py_library")
load("@pip_ros//:requirements.bzl", "requirement")
load("@rosdistro//ament:defs.bzl", "ament_index", "ament_package")
load("@rosdistro//python:defs.bzl", "py_pytest")

package(default_visibility = ["//visibility:public"])

### PYTHON MODULE

py_library(
    name = "launch_testing_ros",
    srcs = glob(["launch_testing_ros/**/*.py"]) + [
        "launch_testing_ros_pytest_entrypoint.py",
    ],
    imports = ["."],
    deps = [
        "@ament_index_python",
        "@launch_ros",
        "@launch_testing",
        "@rclpy",
        requirement("pytest"),
    ],
)

### TESTS

[
    py_pytest(
        name = f.split("/")[-1].removesuffix(".py"),
        srcs = [f],
        args = [
            "-p",
            "launch_testing.pytest.hooks",
            "-p",
            "launch_testing_ros_pytest_entrypoint",
        ],
        data = glob(["test/examples/**"]),
        deps = [
            ":launch_testing_ros",
            "@rules_python//python/runfiles",
            "@std_msgs//:py",
        ],
    )
    for f in glob(
        ["test/examples/*_test.py"],
        exclude = [
            "**/test_flake8.py",
            "**/test_pep257.py",
            "**/test_copyright.py",
            "**/test_xmllint.py",
        ], allow_empty = True)
]

[
    py_pytest(
        name = "test_{0}".format(linter),
        srcs = ["test/test_{0}.py".format(linter)],
        data = glob(["**/*"]),
        deps = ["@ament_{0}".format(linter)],
    )
    for linter in [
        "copyright",
        "flake8",
        "pep257",
        "xmllint",
    ]
]


### PACKAGING

ament_package(
    name = "ament_package",
    package_xml = "package.xml",
    deps = [
        "@ament_copyright//:ament_package",
        "@ament_flake8//:ament_package",
        "@ament_index_python//:ament_package",
        "@ament_pep257//:ament_package",
        "@ament_xmllint//:ament_package",
        "@launch_ros//:ament_package",
        "@launch_testing//:ament_package",
        "@rclpy//:ament_package",
        "@rmw_test_fixture_implementation//:ament_package",
        "@rosdistro//:ament_package",
        "@std_msgs//:ament_package",
        "@osrf_pycommon//:ament_package",
    ]
)
