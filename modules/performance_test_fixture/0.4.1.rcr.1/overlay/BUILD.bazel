load("@rosdistro//ament:defs.bzl", "ament_package")

load("@rules_cc//cc:defs.bzl", "cc_library", "cc_test")

package(default_visibility = ["//visibility:public"])

cc_library(
    name = "performance_test_fixture",
    srcs = glob(["src/**/*.cpp"]),
    hdrs = glob(["include/**/*.hpp"]),
    includes = ["include"],
    deps = [
        "@google_benchmark//:benchmark",
        "@osrf_testing_tools_cpp//:memory_tools",
    ],
)

cc_test(
    name = "benchmark_malloc_realloc",
    timeout = "moderate",
    srcs = [
        "test/benchmark/benchmark_malloc_realloc.cpp",
        "test/benchmark/macros.h",
    ],
    includes = ["include"],
    tags = ["manual"],
    deps = [
        ":performance_test_fixture",
        "@google_benchmark//:benchmark_main",
        "@osrf_testing_tools_cpp//:memory_tools",
    ],
)

cc_test(
    name = "benchmark_malloc_realloc_no_memory_tools",
    timeout = "short",
    srcs = [
        "test/benchmark/benchmark_malloc_realloc_no_memory_tools.cpp",
        "test/benchmark/macros.h",
    ],
    includes = ["include"],
    tags = ["manual"],
    deps = [
        ":performance_test_fixture",
        "@google_benchmark//:benchmark_main",
    ],
)

cc_test(
    name = "benchmark_pause_resume",
    timeout = "short",
    srcs = [
        "test/benchmark/benchmark_pause_resume.cpp",
        "test/benchmark/macros.h",
    ],
    includes = ["include"],
    tags = ["manual"],
    deps = [
        ":performance_test_fixture",
        "@google_benchmark//:benchmark_main",
        "@osrf_testing_tools_cpp//:memory_tools",
    ],
)


### PACKAGING

ament_package(
    name = "ament_package",
    package_xml = "package.xml",
    deps = [
        "@ament_cmake_core//:ament_package",
        "@ament_cmake_export_dependencies//:ament_package",
        "@ament_cmake_export_targets//:ament_package",
        "@ament_cmake_google_benchmark//:ament_package",
        "@ament_cmake_test//:ament_package",
        "@ament_lint_auto//:ament_package",
        "@ament_lint_common//:ament_package",
        "@osrf_testing_tools_cpp//:ament_package",
        "@rosdistro//:ament_package",
    ]
)
